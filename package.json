{
  "name": "uxray",
  "version": "0.1.0",
  "packageManager": "npm@10.5.0",
  "description": "An open-source tool that audits a website for real human usability",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint"
  },
  "keywords": [
    "ux",
    "usability",
    "audit",
    "accessibility",
    "open-source"
  ],
  "devDependencies": {
    "prettier": "^3.8.1",
    "turbo": "^2.3.0"
  }
}
